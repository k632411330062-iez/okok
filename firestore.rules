rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isValidTransaction(data) {
      return data.keys().hasAll(['type', 'amount', 'category', 'date']) &&
             data.type in ['income', 'expense'] &&
             data.amount is number &&
             data.category is string && data.category.size() <= 100 &&
             data.date is string && data.date.size() <= 20 &&
             (data.get('description', '') is string && data.get('description', '').size() <= 500) &&
             (data.get('time', '') is string && data.get('time', '').size() <= 10) &&
             (data.get('paymentMethod', '') is string && data.get('paymentMethod', '').size() <= 100);
    }

    function isValidUserFinance(data) {
      return (data.get('incomeGoal', 0) is number) &&
             (data.get('expenseLimit', 0) is number) &&
             (data.get('simBalances', {}) is map) &&
             (data.get('simInvestments', {}) is map) &&
             (data.get('simMonth', 0) is number);
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Users collection
    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUserFinance(request.resource.data);
      allow update: if isOwner(userId) && isValidUserFinance(request.resource.data);

      // Transactions subcollection
      match /transactions/{transactionId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidTransaction(request.resource.data);
        allow update: if isOwner(userId) && isValidTransaction(request.resource.data);
        allow delete: if isOwner(userId);
      }
    }
  }
}
