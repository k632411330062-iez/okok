[build]
  command = "npm run build"
  publish = "dist"
  functions = "netlify/functions"

[[redirects]]
  from = "/api/chat"
  to = "/.netlify/functions/chat"
  status = 200

[[redirects]]
  from = "/api/gen-analysis"
  to = "/.netlify/functions/analysis"
  status = 200

[[redirects]]
  from = "/api/stock/*"
  to = "/.netlify/functions/stock"
  status = 200

[[redirects]]
  from = "/*"
  to = "/index.html"
  status = 200
